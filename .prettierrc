{
  "tabWidth": 2,
  "useTabs": false,
  "printWidth": 100,
  "plugins": ["prettier-plugin-organize-attributes", "prettier-plugin-css-order"],
  "attributeGroups": [
    "^id$",
    "^class$",
    "^name$",
    "^slot$",

    "^(src|href|type|value|alt|title)$",
    "^data-",

    "^(role|aria-[a-z-]+|tabindex)$",

    "^on[a-z]+",

    "^(width|height|style)$",

    "$DEFAULT"
  ],
  "attributeSort": "ASC",
  "attributeIgnoreCase": true
}

